# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=
PORT=
CLIENT_URL=

# ─── Database ─────────────────────────────────────────────────────────────────
# Update this with your actual MongoDB URI, or keep it as localhost if you have MongoDB running locally
MONGODB_URI=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=

# ─── Google OAuth (optional — leave blank to disable "Sign in with Google") ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# ─── Resend (Email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
